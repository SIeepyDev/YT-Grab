# ----------------------------------------------------------------
# YT Grab -- git ignore list.
# Keep the repo small (source + scripts only). Everything listed
# here is regenerated at launch/build time or is user-local state.
# ----------------------------------------------------------------

# Virtual environment (regenerated by launch.bat on first run)
venv/

# PyInstaller build artifacts
build/
dist/
*.pyc
__pycache__/

# Icon generated from icon.png by build_icon.py
icon.ico

# ffmpeg + ffprobe binaries fetched by fetch_ffmpeg.bat (~100 MB)
bin/

# User-generated state
downloads/
previous_downloads/
history.json
activity.json
settings.json
debug.log

# Stale Chrome profile from the pre-pywebview era
.browser_profile/

# OS / editor noise
.DS_Store
Thumbs.db
.vscode/
.idea/

# Claude session ship helpers (safe to delete after use)
v1.5-commits.md
v1.5-commits.ps1
v1.5-packaging-checklist.md
